DATABASE_URL=postgres://rag:rag@localhost:5432/rag
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
# Required by Auth.js (JWT signing). Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret
# Master key that encrypts provider API keys stored in the DB (AES-256-GCM).
# 32 bytes, base64. Generate with: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
# Target embedding vector width. Baked into the vector(N) DB column — changing it
# requires a schema change and re-indexing. Default 768 (gemini-embedding-2).
# EMBEDDING_DIMENSIONS=768
# Optional: safety-net timeout (ms) for the multimodal PDF parse call. Default 600000 (10 min).
# GOOGLE_PDF_PARSE_TIMEOUT_MS=600000
# Vector store backend: "pgvector" (default), "qdrant", "chroma", "weaviate", or "pinecone".
# VECTOR_STORE=pgvector
# --- Object storage (images, S3-compatible) ---
# Local dev uses MinIO: docker compose up -d minio. In production, point these at any S3.
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=rag-images
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin
S3_FORCE_PATH_STYLE=true
# --- Qdrant (VECTOR_STORE=qdrant) ---
# Start it with: docker compose up -d qdrant, then run: npm run vectorstore:init
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=rag_chunks
# --- Chroma (VECTOR_STORE=chroma) ---
# Start it with: docker compose up -d chroma, then run: npm run vectorstore:init
# CHROMA_URL=http://localhost:8000
# CHROMA_COLLECTION=rag_chunks
# --- Weaviate (VECTOR_STORE=weaviate) ---
# Start it with: docker compose up -d weaviate, then run: npm run vectorstore:init
# WEAVIATE_URL=http://localhost:8080
# WEAVIATE_GRPC_PORT=50051
# WEAVIATE_COLLECTION=RagChunk
# --- Pinecone (VECTOR_STORE=pinecone) ---
# Managed/cloud (no docker). Create an account, get an API key, then run:
#   npm run vectorstore:init   (creates the dense + sparse serverless indexes)
# PINECONE_API_KEY=
# PINECONE_DENSE_INDEX=rag-chunks-dense
# PINECONE_SPARSE_INDEX=rag-chunks-sparse
# PINECONE_CLOUD=aws
# PINECONE_REGION=us-east-1
