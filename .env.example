DATABASE_URL=postgres://rag:rag@localhost:5432/rag
GOOGLE_GENERATIVE_AI_API_KEY=your-key-here
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
# Required by Auth.js (JWT signing). Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret
# Optional: multimodal model used to re-parse layout-heavy PDFs (multi-column,
# tables). Only called when such a layout is detected. Defaults to gemini-2.5-flash.
# GOOGLE_PDF_PARSE_MODEL=gemini-2.5-flash
# Optional: safety-net timeout (ms) for that multimodal call. Default 600000 (10 min).
# GOOGLE_PDF_PARSE_TIMEOUT_MS=600000
