DATABASE_URL=postgres://rag:rag@localhost:5432/rag
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
# Required by Auth.js (JWT signing). Generate with: openssl rand -base64 32
AUTH_SECRET=replace-with-a-random-secret
# Master key that encrypts provider API keys stored in the DB (AES-256-GCM).
# 32 bytes, base64. Generate with: openssl rand -base64 32
SETTINGS_ENCRYPTION_KEY=replace-with-a-32-byte-base64-key
# Target embedding vector width. Baked into the vector(N) DB column — changing it
# requires a schema change and re-indexing. Default 768 (gemini-embedding-2).
# EMBEDDING_DIMENSIONS=768
# Optional: safety-net timeout (ms) for the multimodal PDF parse call. Default 600000 (10 min).
# GOOGLE_PDF_PARSE_TIMEOUT_MS=600000
# Vector store backend: "pgvector" (default) or "qdrant".
# VECTOR_STORE=pgvector
# Required when VECTOR_STORE=qdrant. Run `npm run vectorstore:init` after starting Qdrant
# (docker compose up -d qdrant) to create the collection + full-text index.
# QDRANT_URL=http://localhost:6333
# QDRANT_API_KEY=
# QDRANT_COLLECTION=rag_chunks
