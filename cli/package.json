{
  "name": "rag-boilerplate",
  "version": "0.2.0",
  "description": "Scaffold a full-stack Next.js RAG (retrieval-augmented generation) chat app — create-next-app style, with workspaces, image retrieval and an admin panel, tailored to the AI providers and vector store you choose.",
  "type": "module",
  "bin": { "rag-boilerplate": "dist/index.js" },
  "files": ["dist", "template"],
  "engines": { "node": ">=18" },
  "keywords": [
    "rag",
    "retrieval-augmented-generation",
    "nextjs",
    "boilerplate",
    "starter",
    "scaffold",
    "cli",
    "create-app",
    "ai",
    "chatbot",
    "llm",
    "workspaces",
    "multi-tenant",
    "openai",
    "anthropic",
    "gemini",
    "ollama",
    "vector-database",
    "pgvector",
    "qdrant",
    "chroma",
    "weaviate",
    "pinecone",
    "embeddings",
    "drizzle",
    "typescript"
  ],
  "author": "Serhii Melnikov",
  "license": "MIT",
  "homepage": "https://github.com/SerhiiMelnikov/rag-boilerplate#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SerhiiMelnikov/rag-boilerplate.git",
    "directory": "cli"
  },
  "bugs": {
    "url": "https://github.com/SerhiiMelnikov/rag-boilerplate/issues"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "build:template": "tsx scripts/build-template.ts",
    "test": "vitest run",
    "prepack": "npm run build:template && npm run build"
  },
  "dependencies": {
    "@clack/prompts": "^0.7.0",
    "ts-morph": "^24.0.0",
    "yaml": "^2.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
