{
  "name": "rag-boilerplate",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:up": "docker compose up -d",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/db/migrate.ts",
    "ingest": "tsx scripts/ingest.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "test:integration": "RUN_INTEGRATION=1 vitest run --config vitest.integration.config.ts src/lib/rag/ingest.integration.test.ts src/app/api/admin/documents/upload.integration.test.ts"
  },
  "dependencies": {
    "@ai-sdk/google": "^1.0.0",
    "@headlessui/react": "^2.2.0",
    "ai": "^4.0.0",
    "bcryptjs": "^3.0.3",
    "drizzle-orm": "^0.36.0",
    "mammoth": "^1.8.0",
    "next": "^15.0.0",
    "next-auth": "^5.0.0-beta.31",
    "postgres": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "unpdf": "^0.12.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.0",
    "dotenv": "^16.4.0",
    "drizzle-kit": "^0.28.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
